<mujoco model="quadruped">
  <compiler angle="degree"/>

  <option integrator="RK4" timestep="0.001" cone="elliptic">
    <flag contact="enable"/>
  </option>

  <!-- ====== 纹理和材质 ====== -->
  <asset>
    <!-- 天空渐变背景 -->
    <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="512" height="512"/>
    <!-- 蓝白棋盘格纹理 -->
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1=".2 .4 .6" rgb2=".4 .6 .8"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance="0"/>
  </asset>

  <default>
    <geom friction="1.0 0.02 0.001" solref="0.01 1" solimp="0.9 0.95 0.001"/>
    <joint damping="1.0" armature="0.002"/>
    <default class="leg">
      <geom type="capsule" size="0.03" rgba="0.6 0.6 0.6 1" contype="0" conaffinity="0" density="350"/>
    </default>
    <default class="foot">
      <geom type="sphere" size="0.045" rgba="0.25 0.25 0.25 1"
            friction="1.4 0.04 0.002" condim="4" contype="1" conaffinity="1"
            density="500" solref="0.008 1" solimp="0.95 0.99 0.001"/>
    </default>
  </default>

  <!-- ====== Actuator：13 个电机，位置控制 ====== -->
  <actuator>
    <position name="torso_hinge_act"  joint="torso_hinge"  kp="150" kv="3"/>
    <position name="fl_hip_abd_act"   joint="fl_hip_abd"   kp="60"  kv="1"/>
    <position name="fl_hip_flex_act"  joint="fl_hip_flex"  kp="80"  kv="1.5"/>
    <position name="fl_knee_act"      joint="fl_knee"      kp="60"  kv="1"/>
    <position name="fr_hip_abd_act"   joint="fr_hip_abd"   kp="60"  kv="1"/>
    <position name="fr_hip_flex_act"  joint="fr_hip_flex"  kp="80"  kv="1.5"/>
    <position name="fr_knee_act"      joint="fr_knee"      kp="60"  kv="1"/>
    <position name="hl_hip_abd_act"   joint="hl_hip_abd"   kp="60"  kv="1"/>
    <position name="hl_hip_flex_act"  joint="hl_hip_flex"  kp="80"  kv="1.5"/>
    <position name="hl_knee_act"      joint="hl_knee"      kp="60"  kv="1"/>
    <position name="hr_hip_abd_act"   joint="hr_hip_abd"   kp="60"  kv="1"/>
    <position name="hr_hip_flex_act"  joint="hr_hip_flex"  kp="80"  kv="1.5"/>
    <position name="hr_knee_act"      joint="hr_knee"      kp="60"  kv="1"/>
  </actuator>

  <worldbody>
    <!-- 世界原点坐标轴 (红X 绿Y 蓝Z) -->
    <geom name="axis_x" type="capsule" size="0.01" fromto="0 0 0 0.3 0 0" rgba="1 0 0 0.6" contype="0" conaffinity="0" group="2"/>
    <geom name="axis_y" type="capsule" size="0.01" fromto="0 0 0 0 0.3 0" rgba="0 1 0 0.6" contype="0" conaffinity="0" group="2"/>
    <geom name="axis_z" type="capsule" size="0.01" fromto="0 0 0 0 0 0.3" rgba="0 0 1 0.6" contype="0" conaffinity="0" group="2"/>
    <!-- 原点小球 -->
    <geom name="origin" type="sphere" size="0.02" rgba="1 1 1 0.8" contype="0" conaffinity="0" group="2"/>

    <!-- 聚光灯跟随躯干 -->
    <light name="spotlight" mode="targetbodycom" target="torso_front"
           diffuse="0.9 0.9 0.9" specular="0.3 0.3 0.3" pos="0 -4 4" cutoff="100"/>

    <!-- 地面：碰撞体 -->
    <geom name="floor" type="plane" size="0 0 .05" material="grid"
          friction="1.2 0.03 0.001"
          condim="3" contype="1" conaffinity="1"/>
    <!-- 地面：视觉层（防止 z-fighting） -->
    <geom name="floor_visual" type="plane" size="0 0 .05" pos="0 0 -0.001"
          material="grid" condim="3" contype="0" conaffinity="0" group="1"/>

    <!-- 躯干前半段 (带 freejoint) -->
    <body name="torso_front" pos="0.125 0 0.28">
      <freejoint name="torso_free"/>
      <geom type="box" size="0.125 0.08 0.04" rgba="0.85 0.4 0.15 1"
            density="250" contype="0" conaffinity="0"/>

      <!-- ========== 前左腿 ========== -->
      <body name="fl_abd" pos="0.0 0.08 -0.04">
        <joint name="fl_hip_abd" type="hinge" axis="1 0 0" range="-90 90" damping="1.5"/>
        <geom type="sphere" size="0.005" rgba="0 0 0 0" mass="0.001"/>
        <body name="fl_upper" pos="0 0 0">
          <joint name="fl_hip_flex" type="hinge" axis="0 1 0" range="-60 60" damping="1.5"/>
          <geom class="leg" fromto="0 0 0 0 0 -0.15"/>
          <body name="fl_lower" pos="0 0 -0.15">
            <joint name="fl_knee" type="hinge" axis="0 1 0" range="-120 120" damping="1.2"/>
            <geom class="leg" fromto="0 0 0 0 0 -0.12"/>
            <geom name="fl_lower" class="foot" pos="0 0 -0.12"/>
          </body>
        </body>
      </body>

      <!-- ========== 前右腿 ========== -->
      <body name="fr_abd" pos="0.0 -0.08 -0.04">
        <joint name="fr_hip_abd" type="hinge" axis="1 0 0" range="-90 90" damping="1.5"/>
        <geom type="sphere" size="0.005" rgba="0 0 0 0" mass="0.001"/>
        <body name="fr_upper" pos="0 0 0">
          <joint name="fr_hip_flex" type="hinge" axis="0 1 0" range="-60 60" damping="1.5"/>
          <geom class="leg" fromto="0 0 0 0 0 -0.15"/>
          <body name="fr_lower" pos="0 0 -0.15">
            <joint name="fr_knee" type="hinge" axis="0 1 0" range="-120 120" damping="1.2"/>
            <geom class="leg" fromto="0 0 0 0 0 -0.12"/>
            <geom name="fr_lower" class="foot" pos="0 0 -0.12"/>
          </body>
        </body>
      </body>

      <!-- ====== 躯干后半段 (铰接在前半段后端) ====== -->
      <body name="torso_rear" pos="-0.125 0 0">
        <joint name="torso_hinge" type="hinge" axis="0 1 0" range="-180 180" armature="0.01" damping="3.0"/>
        <geom type="box" size="0.125 0.08 0.04" pos="-0.125 0 0" rgba="0.15 0.5 0.6 1"
              density="250" contype="0" conaffinity="0"/>

        <!-- ========== 后左腿 ========== -->
        <body name="hl_abd" pos="-0.125 0.08 -0.04">
          <joint name="hl_hip_abd" type="hinge" axis="1 0 0" range="-90 90" damping="1.5"/>
          <geom type="sphere" size="0.005" rgba="0 0 0 0" mass="0.001"/>
          <body name="hl_upper" pos="0 0 0">
            <joint name="hl_hip_flex" type="hinge" axis="0 1 0" range="-60 60" damping="1.5"/>
            <geom class="leg" fromto="0 0 0 0 0 -0.15"/>
            <body name="hl_lower" pos="0 0 -0.15">
              <joint name="hl_knee" type="hinge" axis="0 1 0" range="-120 120" damping="1.2"/>
              <geom class="leg" fromto="0 0 0 0 0 -0.12"/>
              <geom name="hl_lower" class="foot" pos="0 0 -0.12"/>
            </body>
          </body>
        </body>

        <!-- ========== 后右腿 ========== -->
        <body name="hr_abd" pos="-0.125 -0.08 -0.04">
          <joint name="hr_hip_abd" type="hinge" axis="1 0 0" range="-90 90" damping="1.5"/>
          <geom type="sphere" size="0.005" rgba="0 0 0 0" mass="0.001"/>
          <body name="hr_upper" pos="0 0 0">
            <joint name="hr_hip_flex" type="hinge" axis="0 1 0" range="-60 60" damping="1.5"/>
            <geom class="leg" fromto="0 0 0 0 0 -0.15"/>
            <body name="hr_lower" pos="0 0 -0.15">
              <joint name="hr_knee" type="hinge" axis="0 1 0" range="-120 120" damping="1.2"/>
              <geom class="leg" fromto="0 0 0 0 0 -0.12"/>
              <geom name="hr_lower" class="foot" pos="0 0 -0.12"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>
